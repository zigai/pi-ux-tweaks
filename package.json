{
  "name": "pi-ui-tweaks",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi package for footer, assistant rendering, and UI tweaks.",
  "keywords": [
    "pi-extension",
    "pi-package",
    "pi-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/pi-ui-tweaks.git"
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint -c ./.oxlintrc.json .",
    "lint:fix": "oxlint -c ./.oxlintrc.json . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "@types/node": "^24.10.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/footer/index.ts",
      "./extensions/assistant-rendering/index.ts",
      "./extensions/loader-time/index.ts"
    ]
  }
}
